# AWS Cost Sentinel Environment Variables
# Copy this file to .env and fill in your actual values

# AWS Credentials (optional if using IAM role)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# Microsoft Teams
TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/YOUR_WEBHOOK_URL

# Slack Integration
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Discord Integration
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK/URL

# SNS Topic (optional)
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:aws-cost-alerts

# Email Configuration (if using SES)
EMAIL_SENDER=alerts@yourcompany.com
EMAIL_RECIPIENTS=devops@yourcompany.com,finance@yourcompany.com

# Application Settings
ENVIRONMENT=development  # development, staging, production
LOG_LEVEL=INFO
